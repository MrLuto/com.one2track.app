{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": ".homeybuild",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "homey"]
  },
  "include": [
    "app.ts",
    "app/**/*.ts",
    "drivers/**/*.ts"
  ],
  "exclude": [
    ".homeybuild",
    "tests"
  ]
}
